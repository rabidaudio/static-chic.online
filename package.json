{
  "name": "cheap-static-sites",
  "private": true,
  "type": "commonjs",
  "version": "1.0.0",
  "description": "Easy and cheap static site hosting on AWS",
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1004.0",
    "@aws-sdk/client-dynamodb": "^3.585.0",
    "@aws-sdk/client-route-53": "^3.1005.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/lib-dynamodb": "^3.585.0",
    "@aws-sdk/lib-storage": "^3.1004.0",
    "@inquirer/prompts": "^8.3.0",
    "@koa/bodyparser": "^6.1.0",
    "@koa/router": "^15.3.1",
    "chalk": "^4.1.0",
    "is-interactive": "^2.0.0",
    "koa": "^3.1.2",
    "lowdb": "^7.0.1",
    "mime-types": "^3.0.2",
    "namor": "^3.0.3",
    "serverless-http": "^3.2.0",
    "simple-git": "^3.32.3",
    "tar": "^7.5.10",
    "winston": "^3.19.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "chai": "^6.2.2",
    "fetch-vcr": "^3.2.0",
    "mocha": "^11.3.0",
    "standard": "^17.1.2"
  },
  "scripts": {
    "serve": "serverless dev",
    "serve:local": "node src/local_server.js",
    "lint": "standard --fix",
    "publish": "dotenvx run -- serverless deploy",
    "admin": "bin/admin",
    "test": "mocha",
    "audit": "npm audit --omit dev"
  },
  "mocha": {
    "timeout": 15000,
    "slow": 3000,
    "spec": [
      "tests/**/*.test.js"
    ]
  },
  "main": "handler.js",
  "directories": {
    "test": "tests"
  },
  "author": "Julien Dorothy, julien@rabidaudio.com",
  "license": "MIT"
}
